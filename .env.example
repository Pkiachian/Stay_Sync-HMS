# Frontend env. Copy to .env and adjust for your machine.
# Vite reads this at dev/build time; restart `npm run dev` after editing.

# Default for local Laravel dev server. Colleagues may set this to their own
# backend host (e.g. http://192.168.1.42:8000/api) or a deployed URL.
VITE_API_URL=http://127.0.0.1:8000/api
