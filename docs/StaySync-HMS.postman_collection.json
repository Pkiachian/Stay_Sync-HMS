{
  "info": {
    "name": "StaySync-HMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "room_type_id", "value": "1" },
    { "key": "room_id", "value": "1" },
    { "key": "guest_id", "value": "1" },
    { "key": "booking_id", "value": "1" },
    { "key": "payment_id", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Front Desk\",\n  \"email\": \"frontdesk@example.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) pm.collectionVariables.set('token', json.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"frontdesk@example.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Current User",
          "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/user" }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/logout" }
        }
      ]
    },
    {
      "name": "Room Types",
      "item": [
        {
          "name": "Create Room Type",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Deluxe Suite\",\n  \"base_price\": 120,\n  \"max_occupancy\": 3,\n  \"amenities\": [\"wifi\", \"breakfast\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/room-types"
          }
        },
        { "name": "List Room Types", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/room-types" } },
        { "name": "Show Room Type", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/room-types/{{room_type_id}}" } }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_type_id\": {{room_type_id}},\n  \"room_number\": \"101\",\n  \"floor\": 1,\n  \"status\": \"available\",\n  \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/rooms"
          }
        },
        { "name": "List Rooms", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/rooms" } },
        { "name": "Show Room", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/rooms/{{room_id}}" } },
        { "name": "Available Rooms", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/available-rooms?check_in_date=2026-06-01&check_out_date=2026-06-03" } }
      ]
    },
    {
      "name": "Guests",
      "item": [
        {
          "name": "Create Guest",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Ada\",\n  \"last_name\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"phone\": \"+254700000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/guests"
          }
        },
        { "name": "List Guests", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/guests" } },
        { "name": "Show Guest", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/guests/{{guest_id}}" } }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guest_id\": {{guest_id}},\n  \"room_id\": {{room_id}},\n  \"room_type_id\": {{room_type_id}},\n  \"check_in_date\": \"2026-06-01\",\n  \"check_out_date\": \"2026-06-03\",\n  \"num_adults\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/bookings"
          }
        },
        { "name": "List Bookings", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/bookings" } },
        { "name": "Show Booking", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/bookings/{{booking_id}}" } },
        { "name": "Check In", "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/bookings/{{booking_id}}/check-in" } },
        { "name": "Check Out", "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/bookings/{{booking_id}}/check-out" } },
        { "name": "Booking Calendar", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/booking-calendar" } }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": {{booking_id}},\n  \"amount\": 150,\n  \"payment_method\": \"cash\",\n  \"payment_date\": \"2026-06-01\",\n  \"reference_number\": \"RCPT-1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/payments"
          }
        },
        { "name": "List Payments", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/payments" } },
        { "name": "Show Payment", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/payments/{{payment_id}}" } }
      ]
    },
    {
      "name": "Reports",
      "item": [
        { "name": "Dashboard Stats", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/dashboard/stats" } },
        { "name": "Revenue Report", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/reports/revenue" } },
        { "name": "Booking Report", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/reports/bookings" } },
        { "name": "Occupancy Report", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{base_url}}/reports/occupancy" } }
      ]
    }
  ]
}
